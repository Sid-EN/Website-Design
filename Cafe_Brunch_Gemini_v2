    <script>
        gsap.registerPlugin(ScrollTrigger);

        // 1. Lenis Smooth Scrolling (Foundation for D/E)
        const lenis = new Lenis({
            duration: 1.5,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            direction: 'vertical',
            smooth: true,
            mouseMultiplier: 1,
            touchMultiplier: 2,
        });

        // E: Motion Blur based on scroll velocity
        const motionContainer = document.querySelector('.motion-blur-container');
        
        lenis.on('scroll', (e) => {
            ScrollTrigger.update();
            // Apply subtle motion blur / skew based on velocity
            if (motionContainer && window.innerWidth > 768) {
                const velocity = Math.abs(e.velocity);
                const blurVal = Math.min(velocity * 0.15, 5); // Cap blur
                const skewVal = Math.max(Math.min(e.velocity * 0.2, 3), -3); // Cap skew
                
                if (velocity > 0.5) {
                    motionContainer.style.filter = `blur(${blurVal}px)`;
                    motionContainer.style.transform = `skewY(${skewVal}deg)`;
                } else {
                    motionContainer.style.filter = `blur(0px)`;
                    motionContainer.style.transform = `skewY(0deg)`;
                }
            }
        });

        gsap.ticker.add((time) => { lenis.raf(time * 1000); });
        gsap.ticker.lagSmoothing(0, 0);

        // 2. Custom Cursor Hover States
        const cursorDot = document.querySelector('.cursor-dot');
        const cursorRing = document.querySelector('.cursor-ring');
        
        window.addEventListener('mousemove', (e) => {
            gsap.to(cursorDot, { x: e.clientX, y: e.clientY, duration: 0.1 });
            gsap.to(cursorRing, { x: e.clientX, y: e.clientY, duration: 0.6, ease: "power3.out" });
        });

        document.querySelectorAll('.hover-target').forEach(el => {
            el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
            el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
        });

        // 3. D: Liquid Wipe Initialization Sequence
        window.addEventListener('load', () => {
            const tl = gsap.timeline();

            // Liquid Wipe Out
            tl.to('#transition-1', {
                clipPath: 'polygon(0 100%, 100% 100%, 100% 100%, 0 100%)',
                duration: 1.2,
                ease: "power4.inOut",
                delay: 0.5
            })
            .to('#transition-2', {
                clipPath: 'polygon(0 100%, 100% 100%, 100% 100%, 0 100%)',
                duration: 1.2,
                ease: "power4.inOut"
            }, "-=0.9")
            // Hero Reveal
            .to('.hero-title', {
                y: '0%',
                duration: 1.2,
                stagger: 0.15,
                ease: "power4.out"
            }, "-=0.5")
            .fromTo('.reveal-fade', {
                y: 20, opacity: 0
            }, {
                y: 0, opacity: 1,
                duration: 1,
                stagger: 0.1,
                ease: "power2.out"
            }, "-=0.8");
        });

        // 4. Scroll Animations (Clips & Staggered Parallax)
        
        // Title Reveal
        gsap.to('.section-title', {
            scrollTrigger: {
                trigger: '#menu',
                start: 'top 75%',
            },
            y: '0%',
            duration: 1.2,
            stagger: 0.1,
            ease: "power4.out"
        });

        // 4-Column Clip Down (D)
        gsap.utils.toArray('.clip-item').forEach(img => {
            gsap.to(img, {
                scrollTrigger: {
                    trigger: img,
                    start: 'top 85%',
                },
                clipPath: 'inset(0% 0 0 0)',
                duration: 1.5,
                ease: "power4.inOut"
            });
        });

        // E: Staggered Scroll Parallax
        if(window.innerWidth > 768) {
            gsap.utils.toArray('.stagger-col').forEach(col => {
                const speed = col.getAttribute('data-speed');
                gsap.to(col, {
                    scrollTrigger: {
                        trigger: '.bento-grid',
                        start: 'top bottom',
                        end: 'bottom top',
                        scrub: 1
                    },
                    y: (i, target) => -ScrollTrigger.maxScroll(window) * (speed - 1) * 0.15,
                    ease: "none"
                });
            });
        }

        // 5. WebGL Background (Simulating Coffee Steam / Aroma)
        const initWebGL = () => {
            const canvas = document.getElementById('webgl-canvas');
            const scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x120f0e, 0.001);

            const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
            
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

            // Create Aroma Particles
            const particlesGeometry = new THREE.BufferGeometry();
            const particlesCount = 300;
            const posArray = new Float32Array(particlesCount * 3);
            
            for(let i = 0; i < particlesCount * 3; i++) {
                posArray[i * 3] = (Math.random() - 0.5) * 30;     // x
                posArray[i * 3 + 1] = (Math.random() - 0.5) * 30; // y
                posArray[i * 3 + 2] = (Math.random() - 0.5) * 15; // z
            }
            
            particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            
            // Texture for smooth particles (optional, using soft round point here)
            const material = new THREE.PointsMaterial({
                size: 0.08,
                color: 0xd4a373,
                transparent: true,
                opacity: 0.4,
                blending: THREE.AdditiveBlending,
                depthWrite: false
            });
            
            const particlesMesh = new THREE.Points(particlesGeometry, material);
            scene.add(particlesMesh);

            camera.position.z = 8;

            // Mouse interaction logic
            let mouseX = 0;
            let mouseY = 0;
            const windowHalfX = window.innerWidth / 2;
            const windowHalfY = window.innerHeight / 2;

            document.addEventListener('mousemove', (event) => {
                mouseX = (event.clientX - windowHalfX) * 0.0005;
                mouseY = (event.clientY - windowHalfY) * 0.0005;
            });

            // Fluid Animation Loop
            const clock = new THREE.Clock();

            const tick = () => {
                const elapsedTime = clock.getElapsedTime();

                // Upward floating motion (like steam)
                particlesMesh.position.y = Math.sin(elapsedTime * 0.2) * 1;
                particlesMesh.rotation.y = elapsedTime * 0.05 + mouseX;
                particlesMesh.rotation.x = mouseY;

                // Subtle wave effect on geometry
                const positions = particlesGeometry.attributes.position.array;
                for(let i = 0; i < particlesCount; i++) {
                    const i3 = i * 3;
                    positions[i3 + 1] += Math.sin(elapsedTime + positions[i3]) * 0.002;
                }
                particlesGeometry.attributes.position.needsUpdate = true;

                renderer.render(scene, camera);
                window.requestAnimationFrame(tick);
            };

            tick();

            // Resize handling
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        };

        initWebGL();
    </script>
</body>
