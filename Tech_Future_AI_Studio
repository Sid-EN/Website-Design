    <style>
        /* Global & Reset */
        body, html {
            margin: 0;
            padding: 0;
            background-color: #030303;
            color: #ffffff;
            overflow-x: hidden;
            cursor: none; /* Hide default cursor for custom GSAP cursor */
        }

        /* Global Noise Texture */
        .noise-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 9999;
            opacity: 0.04;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        /* Custom Cursor - Mix Blend Mode Difference */
        .cursor-dot, .cursor-outline {
            position: fixed;
            top: 0;
            left: 0;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 10000;
            mix-blend-mode: difference;
        }
        .cursor-dot {
            width: 8px;
            height: 8px;
            background-color: white;
        }
        .cursor-outline {
            width: 40px;
            height: 40px;
            border: 1px solid rgba(255, 255, 255, 0.5);
            transition: width 0.3s, height 0.3s, background-color 0.3s;
        }

        /* WebGL Background Canvas */
        #webgl-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* 4-Column Clip Path Stagger / Motion Blur Setup */
        .clip-col {
            will-change: transform, filter;
            clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
        }

        .img-overlay {
            background: linear-gradient(to bottom, rgba(3,3,3,0.2) 0%, #030303 100%);
        }

        /* Infinite Marquee */
        .marquee-container {
            display: flex;
            white-space: nowrap;
            overflow: hidden;
            width: 100vw;
        }
        .marquee-content {
            display: flex;
            animation: marquee 20s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Glassmorphism & Flashlight Hover */
        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 24px;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.4s;
        }
        .glass-card::before {
            content: '';
            position: absolute;
            top: var(--y, 50%);
            left: var(--x, 50%);
            transform: translate(-50%, -50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(0, 240, 255, 0.08) 0%, transparent 60%);
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        .glass-card:hover::before {
            opacity: 1;
        }
        .glass-card:hover {
            border-color: rgba(0, 240, 255, 0.3);
            transform: translateY(-5px);
        }

        /* 1px Glowing Border Beam */
        .glow-beam {
            position: relative;
        }
        .glow-beam::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 1px;
            background: linear-gradient(90deg, transparent, #00F0FF, transparent);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
        }
        .glow-beam:hover::after {
            transform: scaleX(1);
        }

        /* Typography Reveal */
        .reveal-text {
            clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
        }
        .reveal-line {
            transform: translateY(100%);
            display: inline-block;
        }

        /* Utility */
        .content-layer { z-index: 10; position: relative; }
        
        /* Magnetic Button Container */
        .magnetic-wrap {
            display: inline-block;
            padding: 20px;
        }
        .magnetic-btn {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50px;
            padding: 16px 40px;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            position: relative;
            overflow: hidden;
            transition: color 0.3s;
        }
        .magnetic-btn::before {
            content: '';
            position: absolute;
            top: 100%; left: 0; width: 100%; height: 100%;
            background: #ffffff;
            border-radius: 50%;
            transition: top 0.4s cubic-bezier(0.25, 1, 0.5, 1), border-radius 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            z-index: -1;
        }
        .magnetic-btn:hover {
            color: #030303;
        }
        .magnetic-btn:hover::before {
            top: 0;
            border-radius: 0;
        }
    </style>
</head>
