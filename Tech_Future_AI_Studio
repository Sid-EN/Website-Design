    <!-- Scripts -->
    <!-- GSAP Core & ScrollTrigger -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <!-- Lenis for Smooth Scrolling -->
    <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.19/bundled/lenis.min.js"></script>
    <!-- Three.js for WebGL Background -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <script>
        // --------------------------------------------------------
        // 1. Lenis Smooth Scroll Initialization (Essentials)
        // --------------------------------------------------------
        const lenis = new Lenis({
            duration: 1.5,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            direction: 'vertical',
            gestureDirection: 'vertical',
            smooth: true,
            mouseMultiplier: 1,
            smoothTouch: false,
        });

        function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Connect GSAP to Lenis
        gsap.registerPlugin(ScrollTrigger);
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time)=>{
            lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0, 0);


        // --------------------------------------------------------
        // 2. Custom Cursor (Modern Brand)
        // --------------------------------------------------------
        const cursorDot = document.getElementById('cursor-dot');
        const cursorOutline = document.getElementById('cursor-outline');

        window.addEventListener('mousemove', (e) => {
            const posX = e.clientX;
            const posY = e.clientY;

            // Dot follows instantly
            gsap.to(cursorDot, { x: posX, y: posY, duration: 0, ease: "none" });
            
            // Outline follows with slight delay
            gsap.to(cursorOutline, { x: posX, y: posY, duration: 0.15, ease: "power2.out" });
        });

        // Cursor Hover Effects on interactive elements
        const hoverElements = document.querySelectorAll('a, button, .magnetic, .glass-card, iconify-icon');
        hoverElements.forEach(el => {
            el.addEventListener('mouseenter', () => {
                gsap.to(cursorOutline, { scale: 1.8, backgroundColor: "rgba(255,255,255,1)", duration: 0.3 });
                gsap.to(cursorDot, { scale: 0, duration: 0.3 });
            });
            el.addEventListener('mouseleave', () => {
                gsap.to(cursorOutline, { scale: 1, backgroundColor: "transparent", duration: 0.3 });
                gsap.to(cursorDot, { scale: 1, duration: 0.3 });
            });
        });


        // --------------------------------------------------------
        // 3. Magnetic Button Effect (Modern Brand)
        // --------------------------------------------------------
        const magnetics = document.querySelectorAll('.magnetic');
        magnetics.forEach(btn => {
            btn.addEventListener('mousemove', function(e) {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left - rect.width / 2;
                const y = e.clientY - rect.top - rect.height / 2;
                
                gsap.to(this, {
                    x: x * 0.4,
                    y: y * 0.4,
                    duration: 0.5,
                    ease: "power3.out"
                });
            });

            btn.addEventListener('mouseleave', function(e) {
                gsap.to(this, {
                    x: 0,
                    y: 0,
                    duration: 0.7,
                    ease: "elastic.out(1, 0.3)"
                });
            });
        });


        // --------------------------------------------------------
        // 4. Glassmorphism Flashlight Hover (Interaction Pro)
        // --------------------------------------------------------
        document.querySelectorAll('.glass-card').forEach(card => {
            card.addEventListener('mousemove', function(e) {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                this.style.setProperty('--x', `${x}px`);
                this.style.setProperty('--y', `${y}px`);
            });
        });


        // --------------------------------------------------------
        // 5. Hero Intro Animations (Awwwards Extreme - Motion Blur Stagger)
        // --------------------------------------------------------
        const tl = gsap.timeline();

        // Staggered column load with pseudo motion blur
        tl.fromTo(".col-slice", 
            { y: "100vh", filter: "blur(20px)" },
            { y: "0vh", filter: "blur(0px)", duration: 1.5, stagger: 0.1, ease: "power4.out" }
        )
        // Typography reveal
        .fromTo(".hero-title",
            { y: "110%" },
            { y: "0%", duration: 1.2, stagger: 0.1, ease: "power4.out" },
            "-=1.0"
        )
        .fromTo(".hero-sub",
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
            "-=0.5"
        );


        // --------------------------------------------------------
        // 6. ScrollTrigger Section Reveals
        // --------------------------------------------------------
        gsap.fromTo(".section-title",
            { opacity: 0, y: 50 },
            {
                scrollTrigger: {
                    trigger: "#core",
                    start: "top 70%",
                },
                opacity: 1, y: 0, duration: 1, ease: "power3.out"
            }
        );

        gsap.fromTo(".section-desc",
            { opacity: 0, x: -30 },
            {
                scrollTrigger: {
                    trigger: "#core",
                    start: "top 70%",
                },
                opacity: 1, x: 0, duration: 1, delay: 0.2, ease: "power3.out"
            }
        );

        gsap.fromTo(".glass-card",
            { opacity: 0, y: 100 },
            {
                scrollTrigger: {
                    trigger: ".glass-card",
                    start: "top 80%",
                },
                opacity: 1, y: (i, el) => el.classList.contains('md:translate-y-12') ? 48 : 0, 
                duration: 1.2, stagger: 0.15, ease: "power4.out"
            }
        );


        // --------------------------------------------------------
        // 7. Three.js Background (WebGL Visualist)
        // --------------------------------------------------------
        const canvas = document.getElementById('webgl-canvas');
        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x030303, 0.001);

        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 2000);
        camera.position.z = 500;

        const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        // Create Particles network
        const particlesGeometry = new THREE.BufferGeometry();
        const particlesCount = 2000;
        const posArray = new Float32Array(particlesCount * 3);

        for(let i = 0; i < particlesCount * 3; i++) {
            posArray[i] = (Math.random() - 0.5) * 1500;
        }

        particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));

        const material = new THREE.PointsMaterial({
            size: 2,
            color: 0x00F0FF,
            transparent: true,
            opacity: 0.4,
            blending: THREE.AdditiveBlending
        });

        const particlesMesh = new THREE.Points(particlesGeometry, material);
        scene.add(particlesMesh);

        // Mouse interaction with WebGL
        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;

        const windowHalfX = window.innerWidth / 2;
        const windowHalfY = window.innerHeight / 2;

        document.addEventListener('mousemove', (event) => {
            mouseX = (event.clientX - windowHalfX);
            mouseY = (event.clientY - windowHalfY);
        });

        // WebGL Animation Loop
        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const elapsedTime = clock.getElapsedTime();

            targetX = mouseX * 0.05;
            targetY = mouseY * 0.05;

            particlesMesh.rotation.y += 0.0005;
            particlesMesh.rotation.x += 0.0002;

            // Camera subtle movement (Physics feel)
            camera.position.x += (mouseX * 0.5 - camera.position.x) * 0.02;
            camera.position.y += (-mouseY * 0.5 - camera.position.y) * 0.02;
            camera.lookAt(scene.position);

            // Animate points wave
            const positions = particlesMesh.geometry.attributes.position.array;
            for(let i = 0; i < particlesCount; i++) {
                const i3 = i * 3;
                const x = positions[i3];
                // slight sine wave motion on Y
                positions[i3 + 1] += Math.sin(elapsedTime + x) * 0.02;
            }
            particlesMesh.geometry.attributes.position.needsUpdate = true;

            renderer.render(scene, camera);
        }
        animate();

        // Handle Resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

    </script>
</body>
</html>
