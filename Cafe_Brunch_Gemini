    <style>
        /* Base & Resets */
        body {
            background-color: #0f0c0b;
            color: #f5ecd5;
            overflow-x: hidden;
            cursor: none;
        }
        
        ::selection {
            background: #d4af37;
            color: #0f0c0b;
        }

        /* Global Noise Texture (E) */
        .noise-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 9999;
            opacity: 0.06;
            background: url('data:image/svg+xml;utf8,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
        }

        /* Custom Cursor (B) */
        .cursor-dot,
        .cursor-outline {
            position: fixed;
            top: 0;
            left: 0;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            z-index: 10000;
            pointer-events: none;
        }
        .cursor-dot {
            width: 6px;
            height: 6px;
            background-color: #d4af37;
            mix-blend-mode: difference;
        }
        .cursor-outline {
            width: 40px;
            height: 40px;
            border: 1px solid rgba(212, 175, 55, 0.4);
            transition: width 0.2s, height 0.2s, background-color 0.2s;
            mix-blend-mode: difference;
        }
        .cursor-hover .cursor-outline {
            width: 90px;
            height: 90px;
            background-color: rgba(245, 236, 213, 1);
            border-color: transparent;
            backdrop-filter: blur(4px);
            mix-blend-mode: difference;
        }

        /* WebGL Background (D, E) */
        #webgl-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1;
            opacity: 0.4;
            pointer-events: none;
        }

        /* Glassmorphism & 1px Border Beam (B, C) */
        .glass-card {
            background: rgba(245, 236, 213, 0.02);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(245, 236, 213, 0.06);
            position: relative;
            overflow: hidden;
            border-radius: 2rem; /* Advanced Corner Radius */
        }
        .glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.15), transparent);
            transition: left 0.6s ease;
        }
        .glass-card:hover::before {
            left: 100%;
        }

        /* Flashlight Glare / Glow (C) */
        .glow-bg {
            position: absolute;
            width: 70vw;
            height: 70vw;
            max-width: 800px;
            max-height: 800px;
            background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, rgba(15,12,11,0) 60%);
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            z-index: -1;
            transition: transform 0.1s ease-out;
        }

        /* Sonar Pulse (C) */
        .sonar-pulse {
            position: relative;
        }
        .sonar-pulse::after {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 100%; height: 100%;
            border-radius: 50%;
            border: 1px solid #d4af37;
            animation: pulse 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1);
            opacity: 0;
        }
        @keyframes pulse {
            0% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.6; }
            100% { transform: translate(-50%, -50%) scale(2.2); opacity: 0; }
        }

        /* Text Clip Reveal (C) */
        .text-clip-wrapper {
            overflow: hidden;
            display: inline-block;
            vertical-align: top;
        }
        .text-clip {
            transform: translateY(110%);
            display: inline-block;
            transform-origin: left top;
        }

        /* Infinite Marquee (C) */
        .marquee-container {
            display: flex;
            white-space: nowrap;
            overflow: hidden;
        }
        .marquee-content {
            display: flex;
            animation: marquee 25s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Liquid Wipe Transition Overlay (D) */
        .liquid-transition {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: #0f0c0b;
            z-index: 9998;
            clip-path: circle(150% at 50% 100%);
        }

        /* Vertical Container Guides (UI Standards) */
        .guide-lines {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex; justify-content: space-between;
            padding: 0 6vw;
            pointer-events: none;
            z-index: -2;
        }
        .guide-line {
            width: 1px;
            height: 100%;
            background: rgba(245, 236, 213, 0.03);
        }
        
        /* 4-Column Image Clip (D) */
        .img-clip {
            clip-path: inset(100% 0 0 0);
        }

        /* Utility */
        .text-stroke-cream {
            -webkit-text-stroke: 1px rgba(245, 236, 213, 0.15);
            color: transparent;
        }
    </style>
</head>
