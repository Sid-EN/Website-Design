        /* Glassmorphism & 1px Border Beam (B, C) */
        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            overflow: hidden;
            border-radius: 24px;
        }
        .glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 240, 255, 0.1), transparent);
            transition: left 0.5s ease;
        }
        .glass-card:hover::before {
            left: 100%;
        }

        /* Flashlight Glare / Glow (C) */
        .glow-bg {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(112,0,255,0.15) 0%, rgba(0,0,0,0) 70%);
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
            z-index: -1;
            transition: transform 0.1s;
        }

        /* Sonar Pulse (C) */
        .sonar-pulse {
            position: relative;
        }
        .sonar-pulse::after {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 100%; height: 100%;
            border-radius: 50%;
            border: 2px solid #00f0ff;
            animation: pulse 2s infinite cubic-bezier(0.215, 0.61, 0.355, 1);
            opacity: 0;
        }
        @keyframes pulse {
            0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.8; }
            100% { transform: translate(-50%, -50%) scale(2); opacity: 0; }
        }

        /* Text Clip Reveal (C) */
        .text-clip-wrapper {
            overflow: hidden;
            display: inline-block;
        }
        .text-clip {
            transform: translateY(100%);
            display: inline-block;
        }

        /* Infinite Marquee (C) */
        .marquee-container {
            display: flex;
            white-space: nowrap;
            overflow: hidden;
        }
        .marquee-content {
            display: flex;
            animation: marquee 20s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Liquid Wipe Transition Overlay (D) */
        .liquid-transition {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: #000;
            z-index: 9998;
            clip-path: circle(150% at 50% 100%);
