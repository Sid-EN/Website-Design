    <style>
        /* Base & Resets */
        body {
            background-color: #030303;
            color: #ffffff;
            overflow-x: hidden;
            cursor: none; /* Hide default cursor for custom cursor */
        }
        
        ::selection {
            background: #00f0ff;
            color: #000;
